# Server
PORT=3000
NODE_ENV=development

# LLM Provider: Claude | SAP
LLM_TYPE=Claude

# Anthropic (required when LLM_TYPE=Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# SAP LLM (required when LLM_TYPE=SAP)
SAP_LLM_ENDPOINT_URL=https://api.ai.prod.eu-central-1.aws.ml.hana.ondemand.com
SAP_LLM_FOUNDATION_MODEL_TO_USE=anthropic--claude-4.6-sonnet
SAP_LLM_DEPLOYMENT_ID=
SAP_LLM_AUTH_URL=https://sapit-core-playground-vole.authentication.eu10.hana.ondemand.com
SAP_LLM_AUTH_CLIENT_ID=
SAP_LLM_AUTH_CLIENT_SECRET=
SAP_LLM_ANTHROPIC_VERSION=bedrock-2023-05-31

# LLM request limits (shared by both Claude and SAP providers)
LLM_MAX_OUTPUT_TOKENS=16000
LLM_REQUEST_TIMEOUT_SECONDS=600

# Storage paths (relative to backend/)
REPOS_ROOT=./data/repos
OUTPUT_ROOT=./data/outputs

# CORS – frontend origin
FRONTEND_URL=http://localhost:5173

# GitHub (optional – required only for private repositories)
GITHUB_TOKEN=
